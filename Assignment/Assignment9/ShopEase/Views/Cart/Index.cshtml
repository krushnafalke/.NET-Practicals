@model List<ShopEase.Models.Cart>

@{
    double total = 0;
}

<h2>Shopping Cart</h2>

<table class="table table-bordered">

<tr>

<th>Product</th>
<th>Price</th>
<th>Quantity</th>
<th>Total</th>
<th>Action</th>

</tr>

@foreach(var item in Model)
{
    total += item.Total;

<tr>

<td>@item.ProductName</td>

<td>@item.Price</td>

<td>@item.Quantity</td>

<td>@item.Total</td>

<td>

<a asp-action="Increase"
asp-route-id="@item.ProductId"
class="btn btn-success">
+
</a>

<a asp-action="Decrease"
asp-route-id="@item.ProductId"
class="btn btn-warning">
-
</a>

<a asp-action="Remove"
asp-route-id="@item.ProductId"
class="btn btn-danger">
Remove
</a>

</td>

</tr>
}

</table>

<h3>Total = ₹ @total</h3>

<br>

<a asp-action="Checkout"
class="btn btn-primary">

Checkout

</a>

<a asp-action="Clear"
class="btn btn-danger">

Clear Cart

</a>

<form asp-action="ApplyCoupon">

<input type="text"
name="coupon"
placeholder="Enter Coupon"/>

<input type="submit"
value="Apply"
class="btn btn-primary"/>

</form>