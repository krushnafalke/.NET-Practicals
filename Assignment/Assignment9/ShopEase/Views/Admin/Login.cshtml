<h2>Admin Login</h2>

<form method="post">

    <div class="mb-3">
        <label>Username</label>
        <input name="username" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Password</label>
        <input type="password" name="password" class="form-control" />
    </div>

    <button class="btn btn-primary">
        Login
    </button>

</form>

<h4 class="text-danger">
    @ViewBag.Error
</h4>