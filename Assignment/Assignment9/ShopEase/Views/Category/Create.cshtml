@model ShopEase.Models.Category

<h2>Add Category</h2>

<form method="post">

<div class="mb-3">

<label>Category ID</label>

<input asp-for="CategoryId"
class="form-control"/>

</div>

<div class="mb-3">

<label>Category Name</label>

<input asp-for="CategoryName"
class="form-control"/>

</div>

<button class="btn btn-success">

Save

</button>

<a asp-action="Index"
class="btn btn-primary">

View Categories

</a>

</form>

<h4 class="text-danger">

@ViewBag.Error

</h4>